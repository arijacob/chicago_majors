post_bizecon_change = data %>%
group_by(year, cip_code) %>%
summarise(
share_students = sum(total) / first(total_students)
) %>%
group_by(cip_code) %>%
filter(
any(year == 2018 & share_students > 0.005)
) %>%
summarise(
change = share_students[year == 2024] / share_students[year == 2018]
)
