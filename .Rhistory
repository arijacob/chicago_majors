source(paste0(root, "source/mom/mom_functions.R"))
# Compute Panel B/C directly from the four hardcoded priors so the simplified
# table is internally consistent on a per-\$1,000 scale. The upstream CSVs
# also include studies from finaidpersistence.dta scaled in pp (\\times 100),
# which would mix scales (causing variance >> avg sq SE).
priors_2_df <- data.frame(estimate = priors_2$est, se = priors_2$se)
# Compute Panel B/C directly from the four hardcoded priors so the simplified
# table is internally consistent on a per-\$1,000 scale. The upstream CSVs
# also include studies from finaidpersistence.dta scaled in pp (\\times 100),
# which would mix scales (causing variance >> avg sq SE).
priors_2_df <- data.frame(estimate = priors_2$est, se = priors_2$se)
priors_4_df <- data.frame(estimate = priors_4$est, se = priors_4$se)
priors_2 <- priors |> filter(type == "2 year")
# Assumes each CSV has a `type` column with values "2 year" and "4 year".
