values_to = "estimate"
)
meta_summary <- bind_rows(
p10,
p50,
p90
)
write_csv(
meta_summary,
paste0(out_path, "harris_mills_meta_summary.csv")
)
source("~/repo/meta_analysis/prelim.R")
root <- "~/repo/meta_analysis/041_small_meta_analyses/"
# ---- Inputs ----------------------------------------------------------------
in_path  <- paste0(root, "release/")
out_path <- paste0(root, "release/harris_mills_table.tex")
# Assumes each CSV has a `type` column with values "2 year" and "4 year".
# If you instead have separate files per type, swap these reads accordingly,
# e.g. read "harris_mills_mom_aggregation_2year.csv" etc.
d <- read_csv(file.path(in_path, "harris_mills_mom_aggregation.csv")) |>
mutate(across(where(is.numeric), \(x) round(x, 2)))
d_mle <- read_csv(file.path(in_path, "harris_mills_mle_aggregation.csv")) |>
mutate(across(where(is.numeric), \(x) round(x, 2)))
meta_summary <- read_csv(file.path(in_path, "harris_mills_meta_summary.csv")) |>
mutate(across(where(is.numeric), \(x) round(x, 2)))
# Helper: pull the single row for a given type
get_row <- function(df, t) {
out <- df[df$type == t, , drop = FALSE]
if (nrow(out) != 1) stop("Expected one row for type='", t, "' in ",
deparse(substitute(df)))
out
}
d_2  <- get_row(d,     "2 year"); d_4  <- get_row(d,     "4 year")
dm_2 <- get_row(d_mle, "2 year"); dm_4 <- get_row(d_mle, "4 year")
# Prior estimates from the literature
priors <- tribble(
~study, ~type, ~estimate, ~se, ~cost,
"Bartik et al. (2021)",       "2 year",  2.6, 4.0, 6800,
"Carruthers and Fox (2016)",  "2 year",  4.1, 1.4,  971,
"Page et al. (2019)",         "2 year", -3.0, 2.6, 3934,
"Angrist et al. (2021)",      "2 year", -3.2, 0.8, 8200,
"Bartik et al. (2021)",       "4 year",  7.4, 4.0, 6800,
"Carruthers and Fox (2016)",  "4 year", -0.7, 1.3,  971,
"Page et al. (2019)",         "4 year",  7.7, 2.2, 3934,
"Angrist et al. (2021)",      "4 year",  8.1, 1.6, 8200,
) |>
mutate(
estimate = 1000 * estimate / cost,
se       = 1000 * se       / cost
) |>
select(study, type, est = estimate, se)
priors_2 <- priors |> filter(type == "2 year")
priors_4 <- priors |> filter(type == "4 year")
# Sanity-check that study order lines up across the two subgroups
stopifnot(identical(priors_2$study, priors_4$study))
new <- data.frame(
type = c("2 year", "4 year"),
est  = c(0.89, -0.15),
se   = c(0.40,  0.27)
)
new_2 <- new[new$type == "2 year", ]
new_4 <- new[new$type == "4 year", ]
z90 <- qnorm(0.95)
# ---- Helpers ---------------------------------------------------------------
fmt <- function(x, k = 2) formatC(x, format = "f", digits = k)
ci90 <- function(est, se, k = 2) {
lo <- est - z90 * se
hi <- est + z90 * se
sprintf("$(%s,\\ %s)$", fmt(lo, k), fmt(hi, k))
}
# Format one (estimate, se, ci) cell-triplet for one column
cell_triplet <- function(est, se = NA, ci = NA, k_est = 2) {
est_s <- if (length(est) == 0 || is.na(est)) ""   else fmt(est, k_est)
se_s  <- if (length(se)  == 0 || is.na(se))  "--" else sprintf("(%s)", fmt(se, 2))
ci_s  <- if (length(ci)  == 0 || is.na(ci))  "--" else ci
c(est_s, se_s, ci_s)
}
# Build a full row: label + 3 cells for 2-year + 3 cells for 4-year
row2 <- function(label,
est2, se2 = NA, ci2 = NA,
est4, se4 = NA, ci4 = NA,
k_est = 2) {
c2 <- cell_triplet(est2, se2, ci2, k_est)
c4 <- cell_triplet(est4, se4, ci4, k_est)
sprintf("        %s & %s & %s & %s & %s & %s & %s \\\\",
label, c2[1], c2[2], c2[3], c4[1], c4[2], c4[3])
}
# ---- Panel B prep: average squared SE per subgroup -------------------------
avg_sq_se_2 <- mean(priors_2$se^2)
avg_sq_se_4 <- mean(priors_4$se^2)
# Q-profile CIs for tau^2 and tau (formatted strings) per subgroup
qp_ci <- function(lo, hi) sprintf("$(%s,\\ %s)$", fmt(lo, 2), fmt(hi, 2))
ci_tau2_qp_2 <- qp_ci(dm_2$tau_sq_qp_lower90, dm_2$tau_sq_qp_upper90)
ci_tau_qp_2  <- qp_ci(dm_2$tau_qp_lower90,    dm_2$tau_qp_upper90)
ci_tau2_qp_4 <- qp_ci(dm_4$tau_sq_qp_lower90, dm_4$tau_sq_qp_upper90)
ci_tau_qp_4  <- qp_ci(dm_4$tau_qp_lower90,    dm_4$tau_qp_upper90)
# ---- Panel C: new estimates & p-values -------------------------------------
# p-value: two-sided test of new vs precision-weighted mean, per subgroup
pval <- function(new_est, new_se, pw_mean, pw_se) {
z <- (new_est - pw_mean) / sqrt(new_se^2 + pw_se^2)
2 * pnorm(-abs(z))
}
p_new_2 <- pval(new_2$est, new_2$se, d_2$precision, d_2$precision_se)
p_new_4 <- pval(new_4$est, new_4$se, d_4$precision, d_4$precision_se)
# ---- Assemble LaTeX --------------------------------------------------------
prior_rows <- vapply(seq_len(nrow(priors_2)), function(i) {
row2(priors_2$study[i],
priors_2$est[i], priors_2$se[i], ci90(priors_2$est[i], priors_2$se[i]),
priors_4$est[i], priors_4$se[i], ci90(priors_4$est[i], priors_4$se[i]))
}, character(1))
prior_rows
meta_summary_2 <- meta_summary[meta_summary$type == "2 year", , drop = FALSE]
meta_summary_4 <- meta_summary[meta_summary$type == "4 year", , drop = FALSE]
lines <- c(
"\\begin{table}",
"    \\centering",
"    \\caption{Effect of Aid on College Outcomes}",
"    \\begin{tabular}{lcccccc}",
"        \\toprule\\toprule",
"        & \\multicolumn{3}{c}{2-year college effect (pp/ \\$1,000)} & \\multicolumn{3}{c}{4-year college effect (pp/ \\$1,000)} \\\\",
"        \\cmidrule(lr){2-4} \\cmidrule(lr){5-7}",
"        Study & Estimate & SE & 90\\% CI & Estimate & SE & 90\\% CI \\\\",
"        \\midrule",
"        \\textit{Panel A: Prior estimates} & & & & & & \\\\",
prior_rows,
row2("Nguyen, Kramer, and Evans (2019) 10th percentile",
meta_summary_2$estimate[meta_summary_2$percentile = "p10"], NA, NA,
lines <- c(
"\\begin{table}",
"    \\centering",
"    \\caption{Effect of Aid on College Outcomes}",
"    \\begin{tabular}{lcccccc}",
"        \\toprule\\toprule",
"        & \\multicolumn{3}{c}{2-year college effect (pp/ \\$1,000)} & \\multicolumn{3}{c}{4-year college effect (pp/ \\$1,000)} \\\\",
"        \\cmidrule(lr){2-4} \\cmidrule(lr){5-7}",
"        Study & Estimate & SE & 90\\% CI & Estimate & SE & 90\\% CI \\\\",
"        \\midrule",
"        \\textit{Panel A: Prior estimates} & & & & & & \\\\",
prior_rows,
row2("Nguyen, Kramer, and Evans (2019) 10th percentile",
meta_summary_2$estimate[meta_summary_2$percentile == "p10"], NA, NA,
meta_summary_4$estimate[meta_summary_4$percentile == "p10"], NA, NA),
row2("Nguyen, Kramer, and Evans (2019) 50th percentile",
meta_summary_2$estimate[meta_summary_2$percentile == "p50"], NA, NA,
meta_summary_4$estimate[meta_summary_4$percentile == "p50"], NA, NA),
row2("Nguyen, Kramer, and Evans (2019) 90th percentile",
meta_summary_2$estimate[meta_summary_2$percentile == "p90"], NA, NA,
meta_summary_4$estimate[meta_summary_4$percentile == "p90"], NA, NA),
"        \\midrule",
"        \\textit{Panel B: Meta-analytic summary of prior estimates} & & & & & & \\\\",
row2("Between-study variance $\\hat{\\tau}^2$ (equation 1)",
d_2$tau_squared, NA, NA,
d_4$tau_squared, NA, NA),
row2("Simple mean",
d_2$mean, d_2$mean_se, ci90(d_2$mean, d_2$mean_se),
d_4$mean, d_4$mean_se, ci90(d_4$mean, d_4$mean_se)),
row2("Precision-weighted mean (equation 2)",
d_2$precision, d_2$precision_se, ci90(d_2$precision, d_2$precision_se),
d_4$precision, d_4$precision_se, ci90(d_4$precision, d_4$precision_se)),
row2("Variance of estimates",
d_2$estimate_var, d_2$se_var, ci90(d_2$estimate_var, d_2$se_var),
d_4$estimate_var, d_4$se_var, ci90(d_4$estimate_var, d_4$se_var)),
row2("Average squared standard error",
avg_sq_se_2, NA, NA,
avg_sq_se_4, NA, NA),
row2("$\\hat{\\tau}^2$",
(dm_2$mle_tau)^2, NA, ci90((dm_2$mle_tau)^2, (dm_2$mle_se_tau)^2),
(dm_4$mle_tau)^2, NA, ci90((dm_4$mle_tau)^2, (dm_4$mle_se_tau)^2)),
row2("$\\hat{\\tau}$",
dm_2$mle_tau, NA, ci90(dm_2$mle_tau, dm_2$mle_se_tau),
dm_4$mle_tau, NA, ci90(dm_4$mle_tau, dm_4$mle_se_tau)),
row2("MLE mean",
dm_2$mle_mu, dm_2$mle_se_mu, ci90(dm_2$mle_mu, dm_2$mle_se_mu),
dm_4$mle_mu, dm_4$mle_se_mu, ci90(dm_4$mle_mu, dm_4$mle_se_mu)),
row2("MLE $\\hat{\\tau}^2$ (Q-profile 90\\% CI)",
(dm_2$mle_tau)^2, NA, ci_tau2_qp_2,
(dm_4$mle_tau)^2, NA, ci_tau2_qp_4),
row2("MLE $\\hat{\\tau}$ (Q-profile 90\\% CI)",
dm_2$mle_tau, NA, ci_tau_qp_2,
dm_4$mle_tau, NA, ci_tau_qp_4),
"        \\midrule",
"        \\textit{Panel C: New estimate} & & & & & & \\\\",
row2("Siegloch et al. (2025)",
new_2$est, new_2$se, ci90(new_2$est, new_2$se),
new_4$est, new_4$se, ci90(new_4$est, new_4$se)),
row2("$p$-value vs.\\ precision-weighted mean",
p_new_2, NA, NA,
p_new_4, NA, NA),
"        \\bottomrule",
"    \\end{tabular}",
"\\end{table}"
)
writeLines(lines, out_path)
cat("Wrote ", out_path, "\n", sep = "")
cat("\n----- Preview -----\n")
cat(paste(lines, collapse = "\n"), "\n")
theme_custom <- function(base_size = 19, base_family = "Georgia") {
theme_minimal(base_size = base_size, base_family = base_family) +
theme(
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_line(linetype = "solid", color = "grey90",
linewidth = .25),
panel.grid.minor = element_blank(),
axis.ticks = element_line(color = "black"),
axis.ticks.length = unit(0.1, "cm"),
# Add axis lines
axis.line = element_line(color = "black", linewidth = 0.3),
title = element_text(size = 18),
legend.text = element_text(size = 16),
legend.key.size  = unit(1.2, "cm")
)
}
