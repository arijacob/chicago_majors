"       \\textit{Panel D: New estimate} & & & \\\\",
sprintf("        %s & %s & (%s) & %s \\\\",
new_study$label,
fmt(new_study$est, 2),
fmt(new_study$se, 3),
ci90(new_study$est, new_study$se)),
row("$p$-value vs.\\ precision-weighted mean", p_new),
"        \\bottomrule\\bottomrule",
notes_lines,
"    \\end{tabular}",
"\\end{table}"
)
writeLines(lines, out_path)
cat("Wrote ", out_path, "\n", sep = "")
invisible(lines)
}
