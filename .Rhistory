# e.g. read "harris_mills_mom_aggregation_2year.csv" etc.
d <- read_csv(file.path(in_path, "harris_mills_mom_aggregation.csv")) |>
mutate(across(where(is.numeric), \(x) round(x, 2)))
d_mle <- read_csv(file.path(in_path, "harris_mills_mle_aggregation.csv")) |>
mutate(across(where(is.numeric), \(x) round(x, 2)))
meta_summary <- read_csv(file.path(in_path, "harris_mills_meta_summary.csv")) |>
mutate(across(where(is.numeric), \(x) round(x, 2)))
meta_summary_2 <- meta_summary[meta_summary$type == "2 year", , drop = FALSE]
meta_summary_4 <- meta_summary[meta_summary$type == "4 year", , drop = FALSE]
# Helper: pull the single row for a given type
get_row <- function(df, t) {
out <- df[df$type == t, , drop = FALSE]
if (nrow(out) != 1) {
stop(
"Expected one row for type='", t, "' in ",
deparse(substitute(df))
)
}
out
}
d_2 <- get_row(d, "2 year")
d_4 <- get_row(d, "4 year")
dm_2 <- get_row(d_mle, "2 year")
dm_4 <- get_row(d_mle, "4 year")
# Prior estimates from the literature
priors <- tribble(
~study, ~type, ~estimate, ~se, ~cost,
"Bartik et al. (2021)", "2 year", 2.6, 4.0, 6800,
"Carruthers and Fox (2016)", "2 year", 4.1, 1.4, 971,
"Page et al. (2019)", "2 year", -3.0, 2.6, 3934,
"Angrist et al. (2021)", "2 year", -3.2, 0.8, 8200,
"Bartik et al. (2021)", "4 year", 7.4, 4.0, 6800,
"Carruthers and Fox (2016)", "4 year", -0.7, 1.3, 971,
"Page et al. (2019)", "4 year", 7.7, 2.2, 3934,
"Angrist et al. (2021)", "4 year", 8.1, 1.6, 8200,
) |>
mutate(
estimate = 1000 * estimate / cost,
se       = 1000 * se / cost
) |>
select(study, type, est = estimate, se)
priors_2 <- priors |> filter(type == "2 year")
priors_4 <- priors |> filter(type == "4 year")
# Sanity-check that study order lines up across the two subgroups
stopifnot(identical(priors_2$study, priors_4$study))
