df = fread("Documents/Numerical Analysis/final_project/data/goodreads_interactions.csv") %>%
filter(is_read == 1) %>%
select(-is_read) %>%
group_by(user_id) %>%
filter(n() > 1) %>%
group_by(book_id) %>%
filter(n() > 1) %>%
ungroup()
nrow(df)
View(df)
n_distinct(df$user_id)
n_distinct(df$book_id)
ggplot(aes(rating), data = df) +
geom_histogram(binwidth = .5,
bins = 6
) +
labs(x = "Rating", y = "Count") +
scale_y_continuous(labels = scales::comma) +
scale_x_continuous(breaks = 0:5) +
theme_custom() +
theme(
