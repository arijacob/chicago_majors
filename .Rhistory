select(1:3) %>%
mutate(
cip_code = as.character(cip_code),
cip_code = if_else(str_detect(cip_code, "^[0-9]\\."),
paste0("0", cip_code),
cip_code)
) %>%
filter(
!(chicago_major %in% c(
"Applied Math",
"Environmental/Urban Studies",
"Computational and Applied Math",
"Philosophy and Allied Fields"
)
)
) %>%
drop_na()
