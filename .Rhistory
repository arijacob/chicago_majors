summarise(
mean = mean(estimate),
mean_se = simple_mean_se(estimate, se),
precision = precision_mean(estimate, se),
precision_se = precision_mean_se(estimate, se),
tau_squared = compute_tau_squared(estimate, se),
estimate_var = var(estimate),
se_var = var(se),
tau_squared_se = var_tau_squared(estimate),
tau_se = sqrt(tau_squared_se),
.groups = "drop"
) |>
left_join(harris, by = "type") |>
rowwise() |>
mutate(
p_value = 2 * (1 - pnorm(abs(new_estimate - precision) /
sqrt(new_se^2 + precision_se^2)))
) |>
ungroup()
