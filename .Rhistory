library(tidyverse)
library(janitor)
library(sf)
chicago_pop = read_csv("Downloads/czech_noah_thesis/population/nhgis0014_ds45_1920_tract.csv") %>%
rename(czech = A99017) %>%
clean_names()
chicago_tracts <- st_read("Downloads/czech_noah_thesis/shapefile_us_tract_1920/US_tract_1920.shp") %>%
clean_names()
chicago_tracts <- chicago_tracts %>%
left_join(chicago_pop, by = c("gisjoin")) %>%
drop_na(state)
ggplot(chicago_tracts) +
geom_sf(aes(fill = czech), color = "white", size = 0.1) +
scale_fill_gradient(
low = "lightgrey",
high = "red"
) +
theme_minimal() +
labs(
title = "Czech Population in Chicago 1920",
fill = "Total population"
) +
theme(
axis.text = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank()
)
ggsave("czech_population_chicago_1920.png", width = 8, height = 6)
getwd()
ggsave("Downloads/czech_noah_thesis/czech_population_chicago_1920.png", width = 8, height = 6)
