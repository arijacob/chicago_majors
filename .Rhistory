df = fread(paste0(root, "/data/goodreads_interactions.csv")) %>%
filter(is_read == 1) %>%
select(-is_read) %>%
group_by(user_id) %>%
filter(n() > 1) %>%
group_by(book_id) %>%
filter(n() > 1) %>%
ungroup() %>%
group_by(user_id) %>%
filter(
n() <= quantile(n(), 0.99)
)
