source("~/repo/meta_analysis/prelim.R")
source(
"~/repo/meta_analysis/041_small_meta_analyses/source/mle/mle_functions.R"
)
in_path <- "~/repo/meta_analysis/041_small_meta_analyses/input/"
out_path <- "~/repo/meta_analysis/041_small_meta_analyses/release/"
# Harris and Mills (2025) — held out as the "new" study to compare
# against the MLE-based meta mean (rescaled to pp per $1000).
harris_cost <- 3375
harris <- tribble(
~type, ~new_estimate, ~new_se,
"2 year", 3.0 / harris_cost * 1000, 1.35 / harris_cost * 1000,
"4 year", -0.5 / harris_cost * 1000, 0.9 / harris_cost * 1000,
)
# Hardcoded prior studies (rescaled to pp per $1000).
df <- tribble(
~study, ~type, ~estimate, ~se, ~cost,
"Bartik et al. (2021)", "2 year", 2.6, 4.0, 6800,
"Carruthers and Fox (2016)", "2 year", 4.1, 1.4, 971,
"Page et al. (2019)", "2 year", -3.0, 2.6, 3934,
"Angrist et al. (2021)", "2 year", -3.2, 0.8, 8200,
"Bartik et al. (2021)", "4 year", 7.4, 4.0, 6800,
"Carruthers and Fox (2016)", "4 year", -0.7, 1.3, 971,
"Page et al. (2019)", "4 year", 7.7, 2.2, 3934,
"Angrist et al. (2021)", "4 year", 8.1, 1.6, 8200,
) |>
mutate(
estimate = 1000 * estimate / cost,
se       = 1000 * se / cost
)
# Additional studies from the financial-aid persistence database.
finaid <- read_dta(
paste0(in_path, "finaidpersistence.dta")
) |>
distinct() |>
filter(
# Already have these estimates.
!(title %in%
c(
"Effect of the Kalamzoo Promise",
"Losing HOPE: Financial aid and the line between college and work",
"Leveling Up"
)
),
gender == "pooled",
inst_sector != "pooled",
!is.na(treatment_contrast)
) |>
select(
study = leadauth2,
type = inst_sector,
estimate = beta,
se,
treatment_contrast
) |>
mutate(
type = case_when(
type == "2yr" ~ "2 year",
type == "4yr" ~ "4 year",
TRUE ~ NA_character_
),
# beta and se are in proportion units; *100 -> pp; *1000/contrast -> per $1k
estimate = 100 * estimate * 1000 / treatment_contrast,
se       = 100 * se * 1000 / treatment_contrast
) |>
select(-treatment_contrast)
all_estimates <- df |>
select(-cost) |>
bind_rows(finaid)
cat("Input data (per type):\n")
print(all_estimates |> arrange(type, study))
# Fit MLE separately by type, then attach the new-study comparison.
fit_one_type <- function(type_label) {
sub <- filter(all_estimates, type == type_label)
cat(sprintf(
"\n========== %s (k = %d) ==========\n",
type_label, nrow(sub)
))
mle_fit <- fit_mle(sub$estimate, sub$se, label = type_label)
re_row <- mle_fit[mle_fit$method == "MLE (random effects)", ]
fe_row <- mle_fit[mle_fit$method == "MLE (fixed effect, tau=0)", ]
new <- harris |> filter(type == type_label)
cmp <- compare_new_to_mle(new$new_estimate, new$new_se, re_row)
tibble(
type              = type_label,
k                 = nrow(sub),
mle_mu            = re_row$mu,
mle_se_mu         = re_row$se_mu,
mle_tau           = re_row$tau,
mle_se_tau        = re_row$se_tau,
mle_loglik        = re_row$loglik,
fe_mu             = fe_row$mu,
fe_se_mu          = fe_row$se_mu,
lr                = re_row$lr,
p_lr_boundary     = re_row$p_lr,
new_estimate      = new$new_estimate,
new_se            = new$new_se,
p_value           = cmp$p_value,
estimate_var      = var(sub$estimate),
se_var            = var(sub$se),
tau_sq_qp_lower90 = re_row$tau_qp_lower90^2,
tau_sq_qp_upper90 = re_row$tau_qp_upper90^2,
tau_qp_lower90    = re_row$tau_qp_lower90,
tau_qp_upper90    = re_row$tau_qp_upper90
)
}
aggregation <- bind_rows(
fit_one_type("2 year"),
fit_one_type("4 year")
)
cat("\n--- Combined results ---\n")
print(aggregation)
write_csv(
aggregation,
paste0(out_path, "harris_mills_mle_aggregation.csv")
)
